# OpenAI-compatible API configuration
LLM_API_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_ENDPOINT=/chat/completions
LLM_API_KEY=your_api_key_here
LLM_API_MODEL=your-model-id

# Optional task-specific model overrides
# LLM_API_CLASSIFY_MODEL=
# LLM_API_KEYWORDS_MODEL=
# LLM_API_NL2SQL_MODEL=
# LLM_API_ANSWER_MODEL=

# Optional runtime tuning
LLM_API_TIMEOUT=60
LLM_API_TEMPERATURE=0
NUM_PROCESSES=8

# Optional local preprocessing tools
# ANNUAL_REPORT_AGENT_XPDF_PATH=/absolute/path/to/xpdf/bin64
